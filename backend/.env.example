# Backend Environment Configuration for Pharma POS AI
# Copy this file to backend/.env and update the values.
# Never commit backend/.env.

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================
# Recommended production setup for client pharmacies:
# - DATABASE_BACKEND=postgresql
# - PostgreSQL runs on the same local Windows machine as the backend for local installs
DATABASE_BACKEND=postgresql
DATABASE_URL=

POSTGRES_DB=pharma_pos
POSTGRES_USER=pharma_user
POSTGRES_PASSWORD=replace-with-strong-postgres-password
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Hosted tenant backends use their dedicated Render Postgres internal URL.
# The central reporting backend uses the central Supabase Postgres URL.
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE

# ============================================================================
# BACKEND API CONFIGURATION
# ============================================================================
# JWT Secret Key - MUST be at least 32 characters long.
# Generate with: openssl rand -hex 32
SECRET_KEY=replace-with-generated-secret-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

APP_NAME=Pharma POS AI
APP_VERSION=1.0.0
# operational_pos = pharmacy operations against this pharmacy's database.
# cloud_reporting = deployed read-only vendor reporting portal.
# Legacy local_pos/online_pos values are migration aliases only.
APP_MODE=operational_pos
# offline = backend/database run on site; hosted = dedicated remote deployment.
POS_DEPLOYMENT_PROFILE=offline
ENVIRONMENT=production
DEBUG=false

# CORS origins for browsers allowed to call this backend.
BACKEND_CORS_ORIGINS=["http://localhost:3000","http://localhost:5173","http://frontend","http://localhost"]

# ============================================================================
# TIMEZONE AND SCHEDULER
# ============================================================================
TIMEZONE=Africa/Accra
ENABLE_BACKGROUND_SCHEDULER=true
EXPIRY_CHECK_HOUR=9
LOW_STOCK_CHECK_HOUR=10

# Restore drill readiness. A successful drill older than this is considered stale.
RESTORE_DRILL_MAX_AGE_DAYS=90

# ============================================================================
# CENTRAL EVENT PUBLISHING
# ============================================================================
# Operational deployments write events to their transactional outbox. Set this
# true to publish to the central ingestion API. Do not expose sync tokens in
# the frontend.

CLOUD_SYNC_ENABLED=false
CLOUD_SYNC_INGEST_URL=https://your-render-backend.onrender.com/api/sync/ingest
CLOUD_SYNC_API_TOKEN=replace-with-cloud-ingest-token
CLOUD_SYNC_DEPLOYMENT_UID=replace-with-control-plane-deployment-uuid
CLOUD_SYNC_DEVICE_UID=replace-with-registered-device-uid
CLOUD_SYNC_ORGANIZATION_ID=
CLOUD_SYNC_BRANCH_ID=
CLOUD_SYNC_ORGANIZATION_UID=
CLOUD_SYNC_BRANCH_UID=
CLOUD_SYNC_BATCH_SIZE=50
CLOUD_SYNC_TIMEOUT_SECONDS=15
CLOUD_SYNC_MAX_RETRIES=10
CLOUD_SYNC_INTERVAL_MINUTES=5
CLOUD_HEARTBEAT_INTERVAL_MINUTES=5
CLOUD_CATALOG_SNAPSHOT_SYNC_ENABLED=true
CLOUD_CATALOG_SNAPSHOT_SYNC_HOUR=23
CLOUD_CATALOG_SNAPSHOT_SYNC_MINUTE=0
CLOUD_SYNC_REQUIRE_TOKEN=true

# Cloud backend only: project accepted sync events into cloud reporting tables.
# Keep disabled on local branch installs unless the local backend is being used
# as the cloud reporting backend for development.
CLOUD_PROJECTION_ENABLED=false
CLOUD_PROJECTION_INTERVAL_MINUTES=5
CLOUD_PROJECTION_BATCH_SIZE=100

# ============================================================================
# AI MANAGER PROVIDER CONFIGURATION
# ============================================================================
# AI_MANAGER_PROVIDER can be deterministic, openai, claude, or groq.
# If left deterministic but one provider API key is set, the backend auto-selects
# an available provider. Keep provider API keys server-side only.
AI_MANAGER_PROVIDER=deterministic
# Optional. If blank, the backend uses a provider-specific default model.
AI_MANAGER_MODEL=
AI_MANAGER_TIMEOUT_SECONDS=20
AI_MANAGER_MAX_TOKENS=700
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GROQ_API_KEY=

# ============================================================================
# WEEKLY AI MANAGER REPORTS
# ============================================================================
AI_WEEKLY_REPORTS_ENABLED=false
AI_WEEKLY_REPORT_DAY=sun
AI_WEEKLY_REPORT_HOUR=19
AI_WEEKLY_REPORT_MINUTE=0
AI_WEEKLY_REPORT_DELIVERY_ENABLED=false
AI_WEEKLY_REPORT_EMAIL_ENABLED=false
AI_WEEKLY_REPORT_TELEGRAM_ENABLED=false
AI_WEEKLY_REPORT_DELIVERY_TIMEOUT_SECONDS=15
AI_WEEKLY_REPORT_DELIVERY_RETRY_ENABLED=true
AI_WEEKLY_REPORT_DELIVERY_RETRY_INTERVAL_MINUTES=5
AI_WEEKLY_REPORT_DELIVERY_RETRY_BATCH_SIZE=25
AI_WEEKLY_REPORT_DELIVERY_RETRY_BASE_DELAY_MINUTES=10
AI_WEEKLY_REPORT_DELIVERY_RETRY_MAX_DELAY_MINUTES=240
AI_WEEKLY_REPORT_DELIVERY_MAX_ATTEMPTS=3

# Email and Telegram recipients are configured per organization/branch in the
# database through the admin delivery settings endpoint/UI. Do not configure
# global report recipients in environment variables.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=Pharmacy POS
SMTP_USE_TLS=true
SMTP_USE_SSL=false
TELEGRAM_BOT_TOKEN=

# ============================================================================
# BUSINESS RULES
# ============================================================================
LOW_STOCK_THRESHOLD=10
EXPIRY_WARNING_DAYS=30
DEAD_STOCK_DAYS=90

# Customer retention features are deployment flags, not app modes.
CUSTOMER_RETENTION_ENABLED=false
CUSTOMER_RECEIPTS_ENABLED=false
CUSTOMER_FOLLOWUPS_ENABLED=false

# ============================================================================
# FILE STORAGE AND LOGGING
# ============================================================================
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE=5242880
LOG_LEVEL=INFO
LOG_FILE=./logs/app.log

# ============================================================================
# OPTIONAL LOCAL DOCKER ADMIN TOOLING
# ============================================================================
# Used only when the Docker Compose pgadmin profile is enabled.
PGADMIN_DEFAULT_EMAIL=admin@example.local
PGADMIN_DEFAULT_PASSWORD=replace-with-strong-pgadmin-password

# ============================================================================
# NOTES
# ============================================================================
# 1. Never commit backend/.env to version control.
# 2. Generate a strong SECRET_KEY using: openssl rand -hex 32.
# 3. Use strong passwords for POSTGRES_PASSWORD.
# 4. For local production installs, leave DATABASE_URL empty and use POSTGRES_*.
# 5. Hosted tenant deployments use their dedicated Render Postgres URL.
# 6. The central reporting deployment uses the central Supabase Postgres URL.
