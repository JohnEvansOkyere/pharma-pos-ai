# Local pharmacy installation — environment configuration
# setup-env.bat fills in APP_NAME, POSTGRES_PASSWORD, and SECRET_KEY automatically.
# Do not commit this file after values are filled in.

# ----------------------------------------------------------------------------
# DATABASE
# ----------------------------------------------------------------------------
DATABASE_BACKEND=postgresql
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=pharma_pos
POSTGRES_USER=pharma_user
POSTGRES_PASSWORD=replace-with-strong-postgres-password

# ----------------------------------------------------------------------------
# SECURITY
# ----------------------------------------------------------------------------
SECRET_KEY=replace-with-generated-secret-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ----------------------------------------------------------------------------
# APPLICATION
# ----------------------------------------------------------------------------
APP_NAME=Pharma POS AI
APP_VERSION=1.0.0
ENVIRONMENT=production
DEBUG=false
TIMEZONE=Africa/Accra
BACKEND_CORS_ORIGINS=["http://localhost:8080","http://localhost:3000","http://localhost"]

# ----------------------------------------------------------------------------
# SCHEDULER
# ----------------------------------------------------------------------------
ENABLE_BACKGROUND_SCHEDULER=true
EXPIRY_CHECK_HOUR=9
LOW_STOCK_CHECK_HOUR=10

# ----------------------------------------------------------------------------
# BUSINESS RULES
# ----------------------------------------------------------------------------
LOW_STOCK_THRESHOLD=10
EXPIRY_WARNING_DAYS=30
DEAD_STOCK_DAYS=90

# ----------------------------------------------------------------------------
# LOGGING
# ----------------------------------------------------------------------------
LOG_LEVEL=INFO
LOG_FILE=./logs/app.log

# ----------------------------------------------------------------------------
# CLOUD SYNC
# Set CLOUD_SYNC_ENABLED=true to push sales and inventory data to the central
# cloud database. All values below are required when sync is enabled.
# Leave CLOUD_SYNC_ENABLED=false for a fully offline installation.
# ----------------------------------------------------------------------------
CLOUD_SYNC_ENABLED=false
CLOUD_SYNC_INGEST_URL=https://pharma-pos-ai.onrender.com/api/sync/ingest
CLOUD_SYNC_API_TOKEN=replace-with-cloud-sync-token
CLOUD_SYNC_DEVICE_UID=replace-with-unique-device-id
CLOUD_SYNC_ORGANIZATION_ID=replace-with-organization-id
CLOUD_SYNC_BRANCH_ID=replace-with-branch-id
CLOUD_SYNC_INTERVAL_MINUTES=5
CLOUD_SYNC_BATCH_SIZE=50
CLOUD_SYNC_TIMEOUT_SECONDS=15
CLOUD_SYNC_MAX_RETRIES=10

# Cloud projection (read aggregate data back from cloud for dashboard reporting)
CLOUD_PROJECTION_ENABLED=false
CLOUD_PROJECTION_INTERVAL_MINUTES=5
CLOUD_PROJECTION_BATCH_SIZE=100
