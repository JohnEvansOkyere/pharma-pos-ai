# Village/local backend profile.
# Create backend/.env_local, replace placeholders, then select it with:
#   cp backend/.env_local backend/.env

APP_NAME=Pharma POS AI - Local
APP_VERSION=1.0.0
APP_MODE=operational_pos
POS_DEPLOYMENT_PROFILE=offline
ENVIRONMENT=production
DEBUG=false
TIMEZONE=Africa/Accra
TZ=Africa/Accra

# Local PostgreSQL container
DATABASE_BACKEND=postgresql
DATABASE_URL=
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=pharma_pos
POSTGRES_USER=pharma_user
POSTGRES_PASSWORD=replace-with-a-strong-local-database-password

# Authentication
# Generate with: openssl rand -hex 32
SECRET_KEY=replace-with-generated-secret-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

BACKEND_CORS_ORIGINS=["http://localhost:3000","http://localhost:8080","http://localhost"]

# Scheduler and business rules
ENABLE_BACKGROUND_SCHEDULER=true
EXPIRY_CHECK_HOUR=9
LOW_STOCK_CHECK_HOUR=10
LOW_STOCK_THRESHOLD=10
EXPIRY_WARNING_DAYS=30
DEAD_STOCK_DAYS=90

# Fully local by default. Enable only after provisioning this installation.
CLOUD_SYNC_ENABLED=false
CLOUD_SYNC_INGEST_URL=
CLOUD_SYNC_API_TOKEN=
CLOUD_SYNC_DEVICE_UID=
CLOUD_SYNC_ORGANIZATION_ID=
CLOUD_SYNC_BRANCH_ID=
CLOUD_SYNC_INTERVAL_MINUTES=5
CLOUD_HEARTBEAT_INTERVAL_MINUTES=5
CLOUD_CATALOG_SNAPSHOT_SYNC_ENABLED=true
CLOUD_CATALOG_SNAPSHOT_SYNC_HOUR=23
CLOUD_CATALOG_SNAPSHOT_SYNC_MINUTE=0
CLOUD_SYNC_BATCH_SIZE=50
CLOUD_SYNC_TIMEOUT_SECONDS=15
CLOUD_SYNC_MAX_RETRIES=10
CLOUD_PROJECTION_ENABLED=false

# Optional integrations
AI_MANAGER_PROVIDER=deterministic
AI_MANAGER_MODEL=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GROQ_API_KEY=
SMS_PROVIDER=stub
CUSTOMER_RETENTION_ENABLED=false
CUSTOMER_RECEIPTS_ENABLED=false
CUSTOMER_FOLLOWUPS_ENABLED=false

# Local Docker admin tooling
PGADMIN_DEFAULT_EMAIL=admin@localhost
PGADMIN_DEFAULT_PASSWORD=replace-with-a-strong-pgadmin-password

LOG_LEVEL=INFO
LOG_FILE=./logs/app.log
