# Hosted operational backend profile for testing managed PostgreSQL locally.
# Create backend/.env_cloud, replace placeholders, then select it with:
#   cp backend/.env_cloud backend/.env
#
# This is operational_pos, not the reporting-only cloud_reporting mode.

APP_NAME=Pharma POS AI - Hosted
APP_VERSION=1.0.0
APP_MODE=operational_pos
POS_DEPLOYMENT_PROFILE=hosted
ENVIRONMENT=production
DEBUG=false
TIMEZONE=Africa/Accra
TZ=Africa/Accra

# Dedicated Render Postgres instance for this pharmacy organization
DATABASE_BACKEND=postgresql
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE

# The local db service is unused by the backend when DATABASE_URL is set.
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=pharma_pos
POSTGRES_USER=pharma_user
POSTGRES_PASSWORD=unused-cloud-test-local-db-password

# Use the same JWT secret as the cloud backend when compatible tokens are needed.
SECRET_KEY=replace-with-generated-secret-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

BACKEND_CORS_ORIGINS=["http://localhost:3000","http://localhost:8080","http://localhost"]

ENABLE_BACKGROUND_SCHEDULER=true
EXPIRY_CHECK_HOUR=9
LOW_STOCK_CHECK_HOUR=10
LOW_STOCK_THRESHOLD=10
EXPIRY_WARNING_DAYS=30
DEAD_STOCK_DAYS=90

# Publish the tenant outbox to the central ingestion service.
CLOUD_SYNC_ENABLED=true
CLOUD_SYNC_INGEST_URL=https://your-central-backend.onrender.com/api/sync/ingest
CLOUD_SYNC_API_TOKEN=replace-with-tenant-publish-token
CLOUD_PROJECTION_ENABLED=false
CLOUD_SYNC_DEPLOYMENT_UID=
CLOUD_SYNC_DEVICE_UID=
CLOUD_SYNC_ORGANIZATION_ID=
CLOUD_SYNC_BRANCH_ID=
CLOUD_SYNC_ORGANIZATION_UID=
CLOUD_SYNC_BRANCH_UID=

# Optional cloud integrations
AI_MANAGER_PROVIDER=deterministic
AI_MANAGER_MODEL=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GROQ_API_KEY=

SMS_PROVIDER=stub
SMS_USERNAME=
SMS_API_KEY=
SMS_SENDER_ID=PharmaPOS
SMS_CLIENT_ID=
SMS_CLIENT_SECRET=
SMS_FROM_NUMBER=
CUSTOMER_FOLLOWUP_DAYS=3
CUSTOMER_FOLLOWUP_HOUR=10
CUSTOMER_RETENTION_ENABLED=true
CUSTOMER_RECEIPTS_ENABLED=true
CUSTOMER_FOLLOWUPS_ENABLED=true

SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=Pharmacy POS
SMTP_USE_TLS=true
SMTP_USE_SSL=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=

PGADMIN_DEFAULT_EMAIL=admin@localhost
PGADMIN_DEFAULT_PASSWORD=unused-cloud-test-pgadmin-password

LOG_LEVEL=INFO
LOG_FILE=./logs/app.log
