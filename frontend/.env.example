# Frontend Environment Configuration for Pharma POS AI
# Copy this file to frontend/.env.local for local development.
# Only VITE_* variables are exposed to the browser.

# Backend API base URL.
# Local development can use localhost. Vercel production should point to the
# Render backend URL plus /api.
VITE_API_URL=http://localhost:8000/api

# Example for Vercel:
# VITE_API_URL=https://your-render-backend.onrender.com/api

# Notes:
# - Do not put Supabase service-role keys, AI provider keys, SMTP passwords,
#   Telegram bot tokens, or other backend secrets in frontend env files.
# - Cloud sync, AI, email, and Telegram secrets belong in backend/.env only.
